# ============================================================
# Environment Template — Copy to .env and fill your values
# ============================================================

# Application
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false

# API Authentication
# Change this to a secure key in production!
AGENT_API_KEY=sk-your-secure-key-here

# Port (Render assigns this automatically, but useful for local testing)
PORT=8000
HOST=0.0.0.0

# Optional: Database (if needed)
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Optional: Redis (for caching, rate limiting)
# REDIS_URL=redis://redis:6379

# Optional: Qdrant (for vector search)
# QDRANT_URL=http://qdrant:6333
